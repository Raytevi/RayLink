    <style>
        /* Theme: sunset */
        :root { --bg: #ffffff; --text: #1d1d1f; --card-bg: #f5f5f7; }
        @media (prefers-color-scheme: dark) {
            :root { --bg: #000000; --text: #f5f5f7; --card-bg: #1c1c1e; }
