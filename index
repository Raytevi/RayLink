        a { color: #0071e3; text-decoration: none; }
        
        /* Link Blocks */
        .user-link {
            display: block; text-decoration: none;
            background: var(--card-bg);
            padding: 20px; border-radius: 16px;
            color: var(--text); font-weight: 600;
            transition: transform 0.2s;
        }
        .user-link:hover { transform: scale(0.98); }
        .link-url { display: block; font-size: 13px; opacity: 0.5; margin-top: 4px; font-weight: 400; }
        
        
        
        /* Branding */
        .branding { text-align: center; font-size: 12px; opacity: 0.5; margin-top: 40px; }
